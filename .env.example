# ScalAble environment variables
# Copy to .env and adjust values: cp .env.example .env

# Flask
SECRET_KEY=change-me-in-production
DEBUG=True
APP_HOST=127.0.0.1
APP_PORT=5000

# Session store (KeyDB/Redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS / Socket.IO (comma-separated origins)
ALLOWED_ORIGINS=http://127.0.0.1:5000,http://localhost:5000

# Fernet key for encrypting connection credentials in session (required)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Data paths
SPORE_DATA_DIR=./data
KERNEL_DATA_MOUNT=/data

# LLM providers (configure one in spore/_config/settings.json)
OLLAMA_BASE=http://localhost:11434
OLLAMA_ENDPOINT=http://localhost:11434/api/generate
LMSTUDIO_BASE=http://localhost:1234
LMSTUDIO_ENDPOINT=http://localhost:1234

# Cloud LLM API keys (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Optional SQLAlchemy URI (reserved for future persistent app DB)
SQLALCHEMY_URI=
